{
  "framework": "nextjs",
  "buildCommand": "npm run build",
  "installCommand": "npm install",
  "crons": [
    {
      "path": "/api/cron/auto-checkout",
      "schedule": "30 11 * * *"
    },
    {
      "path": "/api/cron/daily-payments-pdf",
      "schedule": "0 12 * * *"
    },
    {
      "path": "/api/cron/pre-arrival",
      "schedule": "0 7 * * *"
    },
    {
      "path": "/api/cron/balance-payment",
      "schedule": "0 7 * * *"
    }
  ]
}
